# Backend Environment Variables
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ai_healthos?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password_here
AI_SERVICE_URL=http://localhost:8000
